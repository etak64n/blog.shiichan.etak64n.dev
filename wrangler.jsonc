{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blog-shiichan",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-07",
  "compatibility_flags": ["nodejs_compat"],
  // Static files in ./public are served from the edge before the Worker runs
  // (e.g. /hero.webp). The Worker handles every other path.
  "assets": { "directory": "./public" },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    { "pattern": "blog.shiichan.etak64n.dev", "custom_domain": true },
    // Legacy spelling, kept so old links 301-redirect (see src/index.ts)
    { "pattern": "blog.sheechan.etak64n.dev", "custom_domain": true }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blog-shiichan",
      "database_id": "70259ab4-400c-47dd-81d9-05068a866fee",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    // GitHub Actions OIDC: only this audience/sub combination may publish
    "OIDC_AUDIENCE": "https://blog.shiichan.etak64n.dev",
    "ALLOWED_OIDC_SUB": "repo:etak64n/shiichan-reporter:ref:refs/heads/main",
    // Domains allowed in source_url. When adding a site to the watcher's
    // sources/*.json, add its domain here and deploy (defense in depth against
    // arbitrary-link injection if auth were ever bypassed)
    "ALLOWED_SOURCE_HOSTS": [
      "aws.amazon.com",
      "blog.cloudflare.com",
      "developers.cloudflare.com",
      "developers.openai.com",
      "openai.com",
      "www.anthropic.com",
      "anthropic.com",
      "claude.com",
      "github.com",
      "jpwinsup.github.io"
    ],
    // Local development only. Keep empty in production (empty = disabled).
    // Override via .dev.vars
    "DEV_BEARER_TOKEN": ""
  }
}
